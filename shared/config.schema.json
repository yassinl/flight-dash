{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weatherdash.local/schemas/config.schema.json",
  "title": "Device Config",
  "type": "object",
  "required": ["radius_miles", "brightness_pct", "refresh_seconds"],
  "properties": {
    "wifi_configured": { "type": "boolean", "default": false },
    "location_source": {
      "type": "string",
      "enum": ["ip", "manual", "browser"],
      "default": "ip"
    },
    "auto_location_enabled": { "type": "boolean", "default": true },
    "latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
    "longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
    "radius_miles": { "type": "number", "minimum": 10, "maximum": 300, "default": 100 },
    "tracked_flight_id": { "type": ["string", "null"] },
    "brightness_pct": { "type": "integer", "minimum": 10, "maximum": 100, "default": 60 },
    "refresh_seconds": { "type": "integer", "minimum": 5, "maximum": 120, "default": 15 }
  }
}
